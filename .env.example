# Matomo MCP Server Configuration
# Copy this file to .env and fill in your values

# Matomo Instance URL (required)
# Your Matomo analytics installation URL
MATOMO_HOST=https://matomo.example.com

# Matomo API Authentication Token (required)
# Get this from Matomo: Settings → Personal → Security → Auth Tokens
MATOMO_TOKEN_AUTH=your_matomo_token_here

# Optional: Default Site ID (default: 1)
# Used when siteId is not specified in tool calls
MATOMO_DEFAULT_SITE_ID=1

# Optional: Request timeout in milliseconds (default: 30000)
# REQUEST_TIMEOUT=30000

# Optional: Number of retry attempts (default: 3)
# RETRY_COUNT=3

# Optional: Initial retry delay in milliseconds (default: 1000)
# RETRY_DELAY=1000
